{
  "openai": {
    "api_key": "PROCESS_ENV_DEEPSEEK_API_KEY",
    "base_url": "https://api.deepseek.com/v1",
    "models": [
      {
        "id": "deepseek-chat",
        "name": "DeepSeek V3",
        "context_window": 65536
      }
