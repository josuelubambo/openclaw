name: Build OpenClaw ZIP

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - uses: actions/setup-node@v4
        with:
          node-version: 22

      - name: Install and Build
        run: |
          corepack enable
          corepack prepare pnpm@latest --activate
          pnpm install --no-frozen-lockfile
          # Build UI si présent
          if grep -q "ui:build" package.json; then pnpm run ui:build; fi
          # Build principal
          if grep -q "\"build\":" package.json; then pnpm run build; fi

      - name: Create Zip
        run: zip -r openclaw-main.zip . -x "*.git*" "node_modules/*"

      - uses: actions/upload-artifact@v4
        with:
          name: openclaw-main
          path: openclaw-main.zip
