name: build-openclaw-zip
on: { workflow_dispatch: {} }

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: 22 }
      - run: corepack enable
      - run: corepack prepare pnpm@10.23.0 --activate
      - run: pnpm install --no-frozen-lockfile
      - run: |
          if jq -e '.scripts["ui:build"]' package.json >/dev/null 2>&1; then pnpm run ui:build; fi
          if jq -e '.scripts.build' package.json >/dev/null 2>&1; then npm run build; fi
      - run: cd .. && zip -r openclaw-main.zip openclaw-main
      - uses: actions/upload-artifact@v4
        with:
          name: openclaw-main
          path: openclaw-main.zip
